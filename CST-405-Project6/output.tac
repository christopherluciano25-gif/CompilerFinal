 77: _sw0 = x
 78: t1 = _sw0 == 1
 79: IF_FALSE t1 GOTO L18
 80: PRINT 10
 81: GOTO L19
 82: L18:
 83: t1 = _sw0 == 2
 84: IF_FALSE t1 GOTO L20
 85: PRINT 20
 86: GOTO L21
 87: L20:
 88: t1 = _sw0 == 3
 89: IF_FALSE t1 GOTO L22
