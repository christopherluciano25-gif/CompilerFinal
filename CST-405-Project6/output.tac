100: _sw1 = x
101: t1 = _sw1 == 1
102: IF_FALSE t1 GOTO L24
103: PRINT 10
104: GOTO L25
105: L24:
106: t1 = _sw1 == 2
107: IF_FALSE t1 GOTO L26
108: PRINT 20
109: GOTO L27
110: L26:
111: PRINT 99
112: L27:
113: L25:
114: PRINT 666
115: x = 5
116: y = 3
117: t1 = x > 3
118: ARG t1
119: t0 = y < 5
120: ARG t0
121: t2 = CALL __and, 2
122: IF_FALSE t2 GOTO L28
123: PRINT 1
124: GOTO L29
125: L28:
126: PRINT 0
127: L29:
128: PRINT 777
129: x = 1
130: y = 10
131: t2 = x > 5
